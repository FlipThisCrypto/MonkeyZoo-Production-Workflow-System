# ── Heavy generated art ─────────────────────────────────────────────
# Reproducible from art_prompt_pack.json (prompts + seeds + engine recipe
# in generation_log.md). Only QA-selected art is tracked.
02_MONTHLY_ISSUES/*/generated_art/raw_panels/
02_MONTHLY_ISSUES/*/generated_art/upscaled/
02_MONTHLY_ISSUES/*/generated_art/edited/

# Print-resolution page masters (rebuild with assemble_pages.py; web_layout
# and social_crops stay tracked as the review record)
02_MONTHLY_ISSUES/*/layout/print_layout/

# Packaged exports (some exceed GitHub's 100MB file limit; rebuild with
# assemble_pages.py + build_release.py)
02_MONTHLY_ISSUES/*/exports/*.pdf
02_MONTHLY_ISSUES/*/exports/*.zip
02_MONTHLY_ISSUES/*/exports/*.cbz

# Rejected outputs, release archive, and local offline backups
04_REJECTED_OUTPUTS/
05_RELEASE_ARCHIVE/
06_BACKUPS/

# ── OS / tooling noise ──────────────────────────────────────────────
__pycache__/
*.pyc
.DS_Store
Thumbs.db
desktop.ini

# ── Local-only files (never publish) ────────────────────────────────
*.local.*
.env
.env.*
issues/

# character-integration-upgrade scratch inspection renders (not pipeline output)
00_SYSTEM/integration_upgrade/_test/

# Full-issue integration: heavy per-panel intermediates are reproducible
# from _specs/ via build_panel.py; only the assembled review pages + specs
# are tracked (repo policy: heavy art gitignored, reproducible from packs).
00_SYSTEM/integration_upgrade/character_layers/
00_SYSTEM/integration_upgrade/poc/*/final_integrated.png
02_MONTHLY_ISSUES/2026-09_Issue_02/generated_art/integration_preview/MZ-2026-09-02_*.png
02_MONTHLY_ISSUES/2026-09_Issue_02/generated_art/integration_preview/*_compare.png
