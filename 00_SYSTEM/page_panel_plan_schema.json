{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "monkeyzoo/page_panel_plan_schema.json",
  "title": "MonkeyZoo Page/Panel Plan",
  "type": "object",
  "required": ["issue_id", "issue_title", "page_count", "pages"],
  "properties": {
    "issue_id": { "type": "string", "pattern": "^MZ-\\d{4}-\\d{2}-\\d{2}$" },
    "issue_title": { "type": "string", "minLength": 1 },
    "page_count": { "type": "integer", "minimum": 1, "maximum": 32 },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["page_number", "page_purpose", "panels"],
        "properties": {
          "page_number": { "type": "integer", "minimum": 1 },
          "page_purpose": { "type": "string", "minLength": 1 },
          "layout_recipe": {
            "type": "string",
            "enum": ["half+half", "third-x3", "full", "splash", "custom"]
          },
          "panels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "panel_id", "characters", "location", "camera_angle",
                "action", "emotion", "dialogue", "caption", "visual_notes",
                "continuity_notes", "art_prompt", "negative_prompt",
                "references_required", "lora_required",
                "controlnet_required", "seed_strategy"
              ],
              "properties": {
                "panel_id": {
                  "type": "string",
                  "pattern": "^MZ-\\d{4}-\\d{2}-\\d{2}_P\\d{2}_PANEL\\d{2}$"
                },
                "panel_size": {
                  "type": "string",
                  "enum": ["half", "third", "full", "splash"]
                },
                "characters": { "type": "array", "items": { "type": "string" } },
                "location": { "type": "string" },
                "camera_angle": { "type": "string" },
                "action": { "type": "string" },
                "emotion": { "type": "string" },
                "dialogue": { "type": "string" },
                "caption": { "type": "string" },
                "sfx": { "type": "string" },
                "visual_notes": { "type": "string" },
                "continuity_notes": { "type": "string" },
                "art_prompt": { "type": "string" },
                "negative_prompt": { "type": "string" },
                "references_required": { "type": "array", "items": { "type": "string" } },
                "lora_required": { "type": "array", "items": { "type": "string" } },
                "controlnet_required": { "type": "string" },
                "seed_strategy": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
