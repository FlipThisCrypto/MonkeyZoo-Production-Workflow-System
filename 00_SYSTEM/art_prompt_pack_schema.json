{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "monkeyzoo/art_prompt_pack_schema.json",
  "title": "MonkeyZoo Art Prompt Pack",
  "type": "object",
  "required": ["issue_id", "style_lock_phrase", "base_negative_prompt", "panels"],
  "properties": {
    "issue_id": { "type": "string", "pattern": "^MZ-\\d{4}-\\d{2}-\\d{2}$" },
    "style_lock_phrase": { "type": "string", "minLength": 20 },
    "base_negative_prompt": { "type": "string", "minLength": 20 },
    "comfyui_defaults": {
      "type": "object",
      "properties": {
        "checkpoint": { "type": "string" },
        "steps": { "type": "integer" },
        "cfg": { "type": "number" },
        "sampler": { "type": "string" },
        "base_resolutions": { "type": "object" }
      }
    },
    "panels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "issue_id", "page_number", "panel_number", "panel_id",
          "character_tokens", "character_design_reminders", "pose",
          "expression", "environment", "camera_angle", "lighting",
          "color_palette", "style_lock_phrase_included", "prompt",
          "negative_prompt", "references_required", "seed_strategy", "seed",
          "controlnet", "identity_stack"
        ],
        "properties": {
          "issue_id": { "type": "string" },
          "page_number": { "type": "integer", "minimum": 0 },
          "panel_number": { "type": "integer", "minimum": 1 },
          "panel_id": { "type": "string" },
          "character_tokens": { "type": "array", "items": { "type": "string" } },
          "character_design_reminders": { "type": "array", "items": { "type": "string" } },
          "pose": { "type": "string" },
          "expression": { "type": "string" },
          "environment": { "type": "string" },
          "camera_angle": { "type": "string" },
          "lighting": { "type": "string" },
          "color_palette": { "type": "string" },
          "style_lock_phrase_included": { "type": "boolean", "const": true },
          "prompt": { "type": "string", "minLength": 40 },
          "negative_prompt": { "type": "string", "minLength": 20 },
          "references_required": { "type": "array", "items": { "type": "string" } },
          "seed_strategy": { "type": "string", "enum": ["per_character_base", "per_panel"] },
          "seed": { "type": "integer" },
          "controlnet": {
            "type": "object",
            "required": ["required"],
            "properties": {
              "required": { "type": "boolean" },
              "type": { "type": "string", "enum": ["openpose", "depth", "canny", "lineart", "none"] },
              "reference": { "type": "string" }
            }
          },
          "identity_stack": {
            "type": "object",
            "required": ["tier"],
            "properties": {
              "tier": { "type": "string", "enum": ["lora", "ipadapter", "text-only"] },
              "lora": { "type": "array", "items": { "type": "string" } },
              "lora_weight": { "type": "number" },
              "ipadapter_refs": { "type": "array", "items": { "type": "string" } }
            }
          },
          "resolution": { "type": "string" },
          "bubble_space_note": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
