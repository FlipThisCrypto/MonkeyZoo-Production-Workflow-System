# Binary assets — never eol-normalize
*.pdf  binary
*.png  binary
*.webp binary
*.jpg  binary
*.jpeg binary
*.zip  binary
*.cbz  binary
*.safetensors binary

# Text — normalize to LF in-repo (required for deterministic static cache-bust hashes)
*.md   text eol=lf
*.json text eol=lf
*.py   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.js   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.svg  text eol=lf
*.ps1  text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
